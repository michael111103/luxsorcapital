// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")        // Ambil dari .env atau Vercel ENV
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

model User {
  id           Int             @id @default(autoincrement())
  name         String
  email        String          @unique
  password     String
  isVerified   Boolean         @default(false)   // ← ADD THIS
  createdAt    DateTime        @default(now())
  verifications Verification[]
}

model Verification {
  id         Int      @id @default(autoincrement())
  code       String
  expiresAt  DateTime
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  // (optional) createdAt jika mau pakai orderBy createdAt
  // createdAt DateTime @default(now())
}

